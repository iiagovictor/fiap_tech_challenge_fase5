# ============================================================
# Storage — cloud-agnostic via fsspec
# ============================================================
# Backend: local | s3 | gcs | azure
STORAGE_BACKEND=local

# Storage URI used by fsspec for all read/write operations:
#   Local:  data/
#   AWS S3: s3://my-bucket/fiap-tc-fase5
#   GCS:    gs://my-bucket/fiap-tc-fase5
#   Azure:  az://my-container/fiap-tc-fase5
STORAGE_URI=data/

# ============================================================
# MLflow
# ============================================================
MLFLOW_TRACKING_URI=http://localhost:5001
MLFLOW_EXPERIMENT_NAME=stock-lstm-prediction
# Artifact root (same fsspec-compatible URI format)
MLFLOW_ARTIFACT_ROOT=s3://mlflow-artifacts

# MinIO Credentials (required for MLflow S3 artifact store)
AWS_ACCESS_KEY_ID=minioadmin
AWS_SECRET_ACCESS_KEY=minioadmin123
MLFLOW_S3_ENDPOINT_URL=http://localhost:9000
AWS_ENDPOINT_URL=http://localhost:9000

# ============================================================
# Feast Feature Store
# ============================================================
FEAST_REPO_PATH=feast/
# Registry path — switch to s3://bucket/feast/registry.pb for AWS
FEAST_REGISTRY_PATH=data/feast/registry.db

# ============================================================
# Online Store (Redis — Feast)
# ============================================================
REDIS_URL=redis://localhost:6379

# ============================================================
# ChromaDB — vector store for RAG
# ============================================================
CHROMA_HOST=localhost
CHROMA_PORT=8002
CHROMA_COLLECTION=market_knowledge

# ============================================================
# LLM — cloud-agnostic via LiteLLM
# ============================================================
# Provider examples:
#   Google Gemini: LLM_MODEL=gemini/gemini-2.0-flash-exp  GOOGLE_API_KEY=AIza...
#   OpenAI       : LLM_MODEL=gpt-4o-mini                  OPENAI_API_KEY=sk-...
#   Ollama (local): LLM_MODEL=ollama/llama3               LLM_BASE_URL=http://localhost:11434
#   Bedrock (AWS): LLM_MODEL=bedrock/anthropic.claude-3-sonnet-20240229-v1:0
#   Azure OpenAI : LLM_MODEL=azure/gpt-4o                 AZURE_API_KEY=...

# Default: Google Gemini (requer API key gratuita)
# Obtenha em: https://makersuite.google.com/app/apikey
LLM_MODEL=gemini/gemini-2.0-flash-exp
LLM_TEMPERATURE=0.0
LLM_MAX_TOKENS=2048

# API Keys (configure pelo menos um)
GOOGLE_API_KEY=sua-chave-aqui
# OPENAI_API_KEY=sk-...
# AZURE_API_KEY=...

# ============================================================
# Data Ingestion
# ============================================================
# Tickers to download (comma-separated)
DATA_TICKERS=ITUB4.SA,PETR4.SA,VALE3.SA,BBDC4.SA,BBAS3.SA,^BVSP
DATA_START_DATE=2020-01-01
DATA_INTERVAL=1d

# ============================================================
# Model Configuration
# ============================================================
MODEL_LSTM_UNITS=50
MODEL_DROPOUT=0.2
MODEL_EPOCHS=50
MODEL_BATCH_SIZE=32
MODEL_SEQ_LENGTH=60

# ============================================================
# AWS (only needed when STORAGE_BACKEND=s3 or deploying to AWS)
# ============================================================
AWS_REGION=us-east-1
AWS_ACCOUNT_ID=123456789012
S3_BUCKET=fiap-tc-fase5-data
S3_MODEL_PREFIX=models/
S3_DATA_PREFIX=data/

# For local MinIO (S3-compatible)
AWS_ACCESS_KEY_ID=minioadmin
AWS_SECRET_ACCESS_KEY=minioadmin123
AWS_ENDPOINT_URL=http://localhost:9000

# ============================================================
# API Configuration
# ============================================================
API_HOST=0.0.0.0
API_PORT=8000
API_WORKERS=1
API_LOG_LEVEL=info

# ============================================================
# Monitoring
# ============================================================
PROMETHEUS_PORT=9090
GRAFANA_PORT=3000
GRAFANA_ADMIN_PASSWORD=admin

# ============================================================
# Security
# ============================================================
# Set to 'true' in production to enable stricter guardrails
ENABLE_GUARDRAILS=true
# Max tokens per request to prevent DoS
MAX_INPUT_TOKENS=1000
MAX_OUTPUT_TOKENS=2000
